{
    "cSpell.import": ["https://cdn.jsdelivr.net/npm/@cspell/dict-en-gb@5/cspell-ext.json"],
    "cSpell.language": "en-GB",
    "cSpell.words": [
        "unlocode",
        "LOCODE",
        "Geist",
        "Vercel"

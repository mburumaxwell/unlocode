{
  "name": "unlocode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "biome format --write",
    "format:check": "biome format",
    "data:download": "node --import tsx ./src/data/scripts/download.ts",
    "data:convert": "node --import tsx ./src/data/scripts/convert.ts",
    "data:refresh": "pnpm data:download && pnpm data:convert",
    "ui-diff": "pnpm exec shadcn diff",
    "ui-gen": "pnpm exec shadcn add --overwrite badge button-group card collapsible combobox field input-group select separator sheet spinner --overwrite",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest",
    "lint": "biome check",
    "clean": "rimraf .next out"
  },
  "dependencies": {
    "@base-ui/react": "1.2.0",
    "@hono/zod-validator": "0.7.6",
    "@hookform/resolvers": "5.2.2",
    "@vercel/analytics": "1.6.1",
    "@vercel/speed-insights": "1.3.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "countries-list": "3.2.2",
    "hono": "4.12.3",
    "lucide-react": "0.575.0",
    "next": "16.1.6",
    "next-themes": "0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.2",
    "shadcn": "3.8.5",
    "shiki": "4.0.0",
    "swr": "2.4.1",
    "tailwind-merge": "3.5.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vercel/config": "0.0.36",
    "babel-plugin-react-compiler": "1.0.0",
    "csv-parse": "6.1.0",
    "postcss": "8.5.6",
    "rimraf": "6.1.3",
    "tailwindcss": "4.2.1",
    "tsx": "4.21.0",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=24.x"
  },
  "packageManager": "pnpm@10.29.3"
}
